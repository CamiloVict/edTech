generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Rol principal en el MVP: un usuario tiene como máximo un rol activo.
enum UserRole {
  CONSUMER
  PROVIDER
}

/// Progreso global del usuario en la app (no confundir con isProfileCompleted del perfil).
enum OnboardingStep {
  PENDING_ROLE
  PENDING_PROFILE
  COMPLETED
}

enum ServiceMode {
  IN_PERSON
  ONLINE
  HYBRID
}

/// Docente vs cuidado / babysitting (un perfil puede ofrecer ambos).
enum ProviderKind {
  TEACHER
  BABYSITTER
}

enum RateUnit {
  HOUR
  SESSION
  DAY
}

enum DwellingType {
  HOUSE
  APARTMENT
}

/// Dónde ocurre la sesión presencial: domicilio de la familia o espacio del educador.
enum InPersonVenueHost {
  CONSUMER
  PROVIDER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED_BY_FAMILY
  CANCELLED_BY_PROVIDER
  COMPLETED
}

/// Quien escribe la reseña vinculada a una cita completada.
enum AppointmentReviewAuthor {
  CONSUMER
  PROVIDER
}

/// Cómo se realiza una cita concreta (p. ej. educador híbrido: la familia elige presencial vs en línea).
enum AppointmentAttendance {
  IN_PERSON
  ONLINE
}

model User {
  id              String          @id @default(cuid())
  clerkUserId     String          @unique @map("clerk_user_id")
  email           String
  role            UserRole?
  onboardingStep  OnboardingStep  @default(PENDING_ROLE) @map("onboarding_step")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  consumerProfile ConsumerProfile?
  providerProfile ProviderProfile?

  supportTicketsCreated     SupportTicket[]         @relation("SupportTicketCreator")
  supportTicketMessages     SupportTicketMessage[]  @relation("SupportTicketMessageAuthor")
  supportTicketEvidenceUploaded SupportTicketEvidence[] @relation("SupportTicketEvidenceUploader")

  @@index([email])
  @@map("users")
}

model ConsumerProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName              String?   @map("full_name")
  phone                 String?
  city                  String?
  /// Dirección completa (calle, número). Solo se muestra en detalle de citas a las partes.
  streetAddress         String?   @map("street_address")
  postalCode            String?   @map("postal_code")
  /// Torre, portal, interior, nombre del edificio, etc.
  unitOrBuilding        String?   @map("unit_or_building")
  dwellingType          DwellingType? @map("dwelling_type")
  relationshipToChild   String?   @map("relationship_to_child")
  /// Foto de perfil (URL o imagen en base64 comprimida desde el cliente).
  photoUrl              String?   @map("photo_url")
  isProfileCompleted    Boolean   @default(false) @map("is_profile_completed")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  children              Child[]
  appointments          Appointment[]
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("consumer_profiles")
}

model ProviderProfile {
  id                    String       @id @default(cuid())
  userId                String       @unique @map("user_id")
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName              String?      @map("full_name")
  bio                   String?
  yearsOfExperience     Int?         @map("years_of_experience")
  focusAreas            String[]     @default([]) @map("focus_areas")
  serviceMode           ServiceMode? @map("service_mode")
  city                  String?
  streetAddress         String?      @map("street_address")
  postalCode            String?      @map("postal_code")
  unitOrBuilding        String?      @map("unit_or_building")
  dwellingType          DwellingType? @map("dwelling_type")
  isProfileCompleted    Boolean      @default(false) @map("is_profile_completed")
  onboardingCompletedAt DateTime?    @map("onboarding_completed_at")
  /// URL de foto (storage propio o CDN); sin modelo de archivos aún.
  photoUrl              String?      @map("photo_url")
  /// Promedio mostrado (reviews reales vendrán después; ahora editable / seed).
  averageRating         Decimal      @default(0) @map("average_rating") @db.Decimal(3, 2)
  ratingCount           Int          @default(0) @map("rating_count")
  isAvailable           Boolean      @default(true) @map("is_available")
  /// Texto libre hasta tener schedules (ej. "Lun–Jue 8:00–14:00").
  availabilitySummary   String?      @map("availability_summary")
  kinds                 ProviderKind[] @default([TEACHER]) @map("kinds")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  rates                 ProviderRate[]
  availabilityBlocks    ProviderAvailabilityBlock[]
  appointments          Appointment[]
  supportTickets        SupportTicket[]

  @@index([isAvailable])
  @@map("provider_profiles")
}

model ProviderRate {
  id                  String       @id @default(cuid())
  providerProfileId   String       @map("provider_profile_id")
  providerProfile     ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  label               String?
  amountMinor         Int          @map("amount_minor")
  currency            String       @default("EUR")
  unit                RateUnit
  sortOrder           Int          @default(0) @map("sort_order")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([providerProfileId])
  @@map("provider_rates")
}

model ProviderAvailabilityBlock {
  id                  String          @id @default(cuid())
  providerProfileId   String          @map("provider_profile_id")
  providerProfile     ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  startsAt            DateTime        @map("starts_at")
  endsAt              DateTime        @map("ends_at")
  isAllDay            Boolean         @default(false) @map("is_all_day")
  /// Zona IANA para interpretar/mostrar bloques de día completo (p. ej. Europe/Madrid).
  timezone            String          @default("UTC")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@index([providerProfileId, startsAt])
  @@map("provider_availability_blocks")
}

model Appointment {
  id                  String             @id @default(cuid())
  providerProfileId   String             @map("provider_profile_id")
  consumerProfileId   String             @map("consumer_profile_id")
  providerProfile     ProviderProfile    @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  consumerProfile     ConsumerProfile    @relation(fields: [consumerProfileId], references: [id], onDelete: Cascade)
  childId             String?            @map("child_id")
  child               Child?             @relation(fields: [childId], references: [id], onDelete: SetNull)
  startsAt            DateTime           @map("starts_at")
  endsAt              DateTime           @map("ends_at")
  status              AppointmentStatus
  /// La familia pide un horario que no encaja en las ventanas publicadas; el educador valora la propuesta.
  requestsAlternativeSchedule Boolean  @default(false) @map("requests_alternative_schedule")
  noteFromFamily      String?            @map("note_from_family")
  /// Enlace de videollamada (Meet, Zoom, etc.) para sesiones en línea o parte virtual.
  meetingUrl          String?            @map("meeting_url")
  /// Si el educador es híbrido, indica si esta cita es presencial o en línea (cuidado solo presencial se fuerza en servidor).
  attendanceMode      AppointmentAttendance? @map("attendance_mode")
  /// Para sesión presencial: si el encuentro es en casa de la familia o en el espacio del educador.
  inPersonVenueHost   InPersonVenueHost  @default(CONSUMER) @map("in_person_venue_host")
  /// Veces que la familia cerró el aviso de reseña sin enviar (máx. 2 en servidor: primera + un recordatorio).
  consumerReviewPromptDismissals Int @default(0) @map("consumer_review_prompt_dismissals")
  /// Veces que el educador cerró el aviso de reseña sin enviar (máx. 2).
  providerReviewPromptDismissals Int @default(0) @map("provider_review_prompt_dismissals")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  reviews             AppointmentReview[]
  supportTickets      SupportTicket[]

  @@index([providerProfileId, startsAt])
  @@index([consumerProfileId, startsAt])
  @@index([status])
  @@map("appointments")
}

model AppointmentReview {
  id              String                   @id @default(cuid())
  appointmentId   String                   @map("appointment_id")
  appointment     Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  authorRole      AppointmentReviewAuthor  @map("author_role")
  stars           Int
  comment         String?
  createdAt       DateTime                 @default(now()) @map("created_at")

  @@unique([appointmentId, authorRole])
  @@index([appointmentId])
  @@map("appointment_reviews")
}

model Child {
  id                String          @id @default(cuid())
  consumerProfileId String          @map("consumer_profile_id")
  consumerProfile   ConsumerProfile @relation(fields: [consumerProfileId], references: [id], onDelete: Cascade)
  firstName         String          @map("first_name")
  birthDate         DateTime        @map("birth_date") @db.Date
  interests         String?
  notes             String?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  appointments      Appointment[]

  @@index([consumerProfileId])
  @@map("children")
}

/// Estado del ticket de soporte / reclamo ligado a una cita.
enum SupportTicketStatus {
  OPEN
  PENDING_USER
  PENDING_AGENT
  RESOLVED
  ESCALATED
}

enum SupportResolutionKind {
  NONE
  AUTO
  HUMAN
}

enum SupportMessageAuthor {
  SYSTEM
  USER
  AGENT
}

/// Categorías guiadas (árbol simple: parentCode opcional).
model SupportComplaintCategory {
  id            String   @id @default(cuid())
  code          String   @unique
  labelEs       String   @map("label_es")
  descriptionEs String?  @map("description_es") @db.Text
  parentCode    String?  @map("parent_code")
  sortOrder     Int      @default(0) @map("sort_order")
  active        Boolean  @default(true)
  /// Pistas para el front (pasos, copy); extensible sin deploy.
  flowHintJson  Json?    @map("flow_hint_json")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([parentCode])
  @@map("support_complaint_categories")
}

/// Reglas de resolución automática evaluadas en orden de `priority` descendente.
model SupportResolutionRule {
  id             String   @id @default(cuid())
  categoryCode   String   @map("category_code")
  name           String
  priority       Int      @default(0)
  conditionsJson Json     @default("{}") @map("conditions_json")
  actionType     String   @map("action_type")
  actionPayload  Json?    @map("action_payload")
  autoConfidence Decimal  @default(0.700) @map("auto_confidence") @db.Decimal(4, 3)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([categoryCode, active])
  @@index([priority])
  @@map("support_resolution_rules")
}

model SupportTicket {
  id                     String                @id @default(cuid())
  appointmentId        String                @map("appointment_id")
  appointment          Appointment           @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdByUserId      String                @map("created_by_user_id")
  createdBy            User                  @relation("SupportTicketCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  providerProfileId    String                @map("provider_profile_id")
  providerProfile      ProviderProfile       @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  categoryCode         String                @map("category_code")
  status               SupportTicketStatus
  resolutionKind       SupportResolutionKind @map("resolution_kind")
  formalComplaint      Boolean               @default(false) @map("formal_complaint")
  formalTrackingNumber String?               @unique @map("formal_tracking_number")
  metadata             Json                  @default("{}")
  proposedResolution   Json?                 @map("proposed_resolution")
  autoConfidence       Decimal?              @map("auto_confidence") @db.Decimal(4, 3)
  abuseScoreSnapshot   Decimal?              @map("abuse_score_snapshot") @db.Decimal(4, 3)
  escalationReason     String?               @map("escalation_reason") @db.Text
  resolvedAt           DateTime?             @map("resolved_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  messages  SupportTicketMessage[]
  evidence  SupportTicketEvidence[]

  @@index([appointmentId])
  @@index([createdByUserId, createdAt])
  @@index([providerProfileId, status])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id           String               @id @default(cuid())
  ticketId     String               @map("ticket_id")
  ticket       SupportTicket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorType   SupportMessageAuthor @map("author_type")
  authorUserId String?              @map("author_user_id")
  authorUser   User?                @relation("SupportTicketMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  body         String               @db.Text
  metadata     Json?
  createdAt    DateTime             @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_ticket_messages")
}

model SupportTicketEvidence {
  id               String        @id @default(cuid())
  ticketId         String        @map("ticket_id")
  ticket           SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedByUserId String        @map("uploaded_by_user_id")
  uploadedBy       User          @relation("SupportTicketEvidenceUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  fileUrl          String        @map("file_url") @db.Text
  mimeType         String?       @map("mime_type")
  label            String?
  createdAt        DateTime      @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("support_ticket_evidence")
}
