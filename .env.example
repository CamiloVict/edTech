# Copia a apps/api/.env y apps/web/.env.local según corresponda.

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/trofoschool?schema=public"

# Clerk — misma instancia en API y web
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# API (Nest)
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Producción (Vercel + Fly) ---
# Front: https://ed-tech-web-six.vercel.app
# La URL de la API en producción está en apps/web/.env.production (NEXT_PUBLIC_API_URL → Fly).
#
# Vercel → Project → Settings → Environment Variables → marcar "Production" (y Preview si quieres):
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_... o pk_live_...
#   CLERK_SECRET_KEY=sk_test_... o sk_live_...
# Sin AMBAS, el middleware de Clerk revienta y Vercel muestra:
#   500 MIDDLEWARE_INVOCATION_FAILED
# Tras añadir variables: Redeploy (Deployments → … → Redeploy).
#
# CORS en Fly: WEB_ORIGIN debe incluir https://ed-tech-web-six.vercel.app (fly secrets list -a trofo-school-api).

# --- Fly.io (API @trofo-school-api, build desde raíz del monorepo) ---
# fly secrets set DATABASE_URL="postgresql://..." CLERK_SECRET_KEY="sk_..." WEB_ORIGIN="https://tu-dominio-web.app"
# WEB_ORIGIN puede ser lista separada por comas si tienes varios orígenes.
# Tras el primer deploy, las migraciones corren con: deploy.release_command en fly.toml
# Desde la raíz: fly deploy
# Postgres en Fly: fly postgres attach --app trofo-school-api <nombre-db-app>

# --- Seed en producción (Prisma) ---
# El seed BORRA todas las tablas de app (users, perfiles, citas, etc.) y vuelve a insertar datos demo.
# Los educadores del seed no coinciden con usuarios reales de Clerk (clerkUserId ficticios); sirve para
# catálogo demo en /explorar si la DB de prod está vacía o es solo staging.
#
# Desde la raíz del monorepo, con URL de la DB de Fly (fly postgres connect / dashboard / secrets):
#   export DATABASE_URL="postgres://..."
#   ALLOW_SEED_RESET=true NODE_ENV=production pnpm --filter @repo/database exec prisma db seed
#
# Sin ALLOW_SEED_RESET en production, el seed aborta. En local (sin NODE_ENV=production) sigue borrando y sembrando como siempre.
