# Variables para Vercel (Project → Settings → Environment Variables).
# `next build` usa apps/web/.env.production para NEXT_PUBLIC_* concretos del repo;
# el resto se configura solo en el dashboard de Vercel (no commitear secretos).
#
# Production (y Preview si aplica):
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_... o pk_live_...
#   CLERK_SECRET_KEY=sk_test_... o sk_live_...   (middleware / servidor)
#   NEXT_PUBLIC_API_URL=https://trofo-school-api.fly.dev   (o tu URL de API)
#
# Vercel no necesita DATABASE_URL: la base de datos la usa solo la API en Fly.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_API_URL=
