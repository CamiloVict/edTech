# Debe coincidir con el Postgres que escucha en el puerto indicado (p. ej. docker-compose en la raíz).
# Si la API falla al arrancar con Prisma P1000, usuario/contraseña o puerto no coinciden con ese servidor.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/trofoschool?schema=public"
CLERK_SECRET_KEY="sk_test_..."
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Stripe (Connect + PaymentIntents captura manual). Test keys en https://dashboard.stripe.com/test/apikeys
# Sin Connect activado en el Dashboard, crear cuentas Express de educadores falla: https://dashboard.stripe.com/test/connect/account/overview
STRIPE_SECRET_KEY=
# Clave «Publishable key» estándar (pk_test_… / pk_live_…). No uses restricted (rk_…) ni secret (sk_) aquí.
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Comisión plataforma en basis points (1000 = 10%). Opcional.
STRIPE_PLATFORM_FEE_BPS=1000
# País por defecto al crear cuentas Express de educadores (ISO 3166-1 alpha-2).
STRIPE_CONNECT_DEFAULT_COUNTRY=US
