# Debe coincidir con el Postgres que escucha en el puerto indicado (p. ej. docker-compose en la raíz).
# Si la API falla al arrancar con Prisma P1000, usuario/contraseña o puerto no coinciden con ese servidor.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/trofoschool?schema=public"
CLERK_SECRET_KEY="sk_test_..."
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Correo (Nodemailer). Sin esto, los avisos de ticket solo se registran en log y no se envían.
# Gmail: usar contraseña de aplicación en SMTP_PASS (https://support.google.com/accounts/answer/185833).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=
MAIL_FROM="Edify <tu_cuenta@gmail.com>"
# Bandeja interna de soporte (por defecto: camiloavict+edify@gmail.com).
SUPPORT_NOTIFY_EMAIL=camiloavict+edify@gmail.com
